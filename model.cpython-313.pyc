
import math
import numpy as np
import pandas as pd
from core.db import last_home, last_away

def poisson(k, lam):
    if lam <= 0:
        return 0
    return math.exp(-lam) * (lam ** k) / math.factorial(k)

def fair_odd(prob):
    return np.nan if prob <= 0 else 1 / prob

def estimate_lambdas(home, away, league):
    h = last_home(home, league, 10)
    a = last_away(away, league, 10)
    if h.empty or a.empty:
        return 1.25, 1.05, "Sem dados suficientes. Usando média padrão."
    home_gf = h["home_goals"].mean()
    home_ga = h["away_goals"].mean()
    away_gf = a["away_goals"].mean()
    away_ga = a["home_goals"].mean()
    lh = home_gf * 0.55 + away_ga * 0.45
    la = away_gf * 0.55 + home_ga * 0.45
    return max(0.1, min(4, lh)), max(0.1, min(4, la)), ""

def score_matrix(lh, la, max_goals=8):
    rows = []
    for h in range(max_goals + 1):
        for a in range(max_goals + 1):
            rows.append({"home":h, "away":a, "prob":poisson(h, lh) * poisson(a, la)})
    df = pd.DataFrame(rows)
    s = df["prob"].sum()
    if s > 0:
        df["prob"] = df["prob"] / s
    return df

def markets(lh, la):
    df = score_matrix(lh, la)
    margin = df["home"] - df["away"]
    total = df["home"] + df["away"]
    p_home = df.loc[margin > 0, "prob"].sum()
    p_draw = df.loc[margin == 0, "prob"].sum()
    p_away = df.loc[margin < 0, "prob"].sum()
    btts = df.loc[(df["home"] > 0) & (df["away"] > 0), "prob"].sum()
    rows = [
        {"market":"Casa ML", "prob":p_home},
        {"market":"Empate", "prob":p_draw},
        {"market":"Fora ML", "prob":p_away},
        {"market":"Casa DNB", "prob":p_home + 0.5*p_draw},
        {"market":"Fora DNB", "prob":p_away + 0.5*p_draw},
        {"market":"BTTS Sim", "prob":btts},
        {"market":"BTTS Não", "prob":1-btts},
    ]
    for line in [0.5,1.5,2.5,3.5,4.5]:
        over = df.loc[total > line, "prob"].sum()
        rows.append({"market":f"Over {line}", "prob":over})
        rows.append({"market":f"Under {line}", "prob":1-over})
    for line in [-1.5,-1.0,-0.5,0,0.5,1.0,1.5]:
        hwin = df.loc[(margin + line) > 0, "prob"].sum()
        hpush = df.loc[(margin + line) == 0, "prob"].sum()
        awin = df.loc[(-margin + line) > 0, "prob"].sum()
        apush = df.loc[(-margin + line) == 0, "prob"].sum()
        rows.append({"market":f"Casa AH {line:+}", "prob":hwin + 0.5*hpush})
        rows.append({"market":f"Fora AH {line:+}", "prob":awin + 0.5*apush})
    out = pd.DataFrame(rows)
    out["fair_odd"] = out["prob"].apply(fair_odd)
    return out

def kelly(prob, odd):
    if odd <= 1:
        return 0
    b = odd - 1
    return max(0, (b*prob - (1-prob)) / b)

def compare(market_df, odds_df, bankroll, min_edge):
    if odds_df is None or odds_df.empty:
        return pd.DataFrame()
    if not {"market","odd"}.issubset(odds_df.columns):
        return pd.DataFrame()
    df = odds_df.merge(market_df, on="market", how="inner")
    if df.empty:
        return df
    df["edge"] = df["odd"] / df["fair_odd"] - 1
    df["ev"] = df["prob"] * df["odd"] - 1
    df["kelly"] = df.apply(lambda r: kelly(r["prob"], r["odd"]), axis=1)
    df["stake"] = (df["kelly"] * 0.25 * bankroll).clip(0, bankroll*0.03)
    df["decision"] = df.apply(lambda r: "🟢 ENTRADA" if r["edge"] >= min_edge and r["ev"] > 0 else ("🟡 Valor leve" if r["ev"] > 0 else "🔴 Passar"), axis=1)
    return df.sort_values("edge", ascending=False)
