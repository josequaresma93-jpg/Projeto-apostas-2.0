from datetime import date
import streamlit as st
from core.database import add_match, add_fixture, import_matches_csv, import_fixtures_csv, get_matches, get_fixtures
from services.seed import seed_sample_data

st.title('📚 Banco de Jogos')
tab1,tab2,tab3=st.tabs(['Resultados','Jogos futuros','Importações'])
with tab1:
    with st.form('novo_resultado'):
        c1,c2,c3=st.columns(3); match_date=c1.date_input('Data',value=date.today()); league=c2.text_input('Liga','Série B'); home=c3.text_input('Mandante','Vila Nova')
        c4,c5,c6=st.columns(3); away=c4.text_input('Visitante','Novorizontino'); hg=c5.number_input('Gols mandante',0,20,1); ag=c6.number_input('Gols visitante',0,20,1)
        c7,c8=st.columns(2); xgh=c7.number_input('xG mandante opcional',0.0,10.0,0.0,0.05); xga=c8.number_input('xG visitante opcional',0.0,10.0,0.0,0.05)
        if st.form_submit_button('Salvar resultado'):
            add_match(match_date,league,home,away,hg,ag,xgh,xga); st.success('Resultado salvo.')
    league_filter=st.text_input('Filtrar liga resultados','Série B')
    st.dataframe(get_matches(league_filter),use_container_width=True)
with tab2:
    with st.form('novo_fixture'):
        c1,c2,c3,c4=st.columns(4); fixture_date=c1.date_input('Data do jogo',value=date.today()); league_f=c2.text_input('Liga do jogo','Série B'); home_f=c3.text_input('Mandante futuro','Vila Nova'); away_f=c4.text_input('Visitante futuro','Novorizontino')
        if st.form_submit_button('Salvar jogo futuro'):
            add_fixture(fixture_date,league_f,home_f,away_f); st.success('Jogo futuro salvo.')
    st.dataframe(get_fixtures(),use_container_width=True)
with tab3:
    uploaded=st.file_uploader('Importar resultados CSV',type=['csv'])
    if uploaded and st.button('Importar resultados'):
        try: st.success(f'{import_matches_csv(uploaded)} resultados importados.')
        except Exception as e: st.error(str(e))
    uploaded_f=st.file_uploader('Importar jogos futuros CSV',type=['csv'])
    if uploaded_f and st.button('Importar jogos futuros'):
        try: st.success(f'{import_fixtures_csv(uploaded_f)} jogos futuros importados.')
        except Exception as e: st.error(str(e))
    if st.button('Carregar dados de exemplo'):
        seed_sample_data(); st.success('Dados de exemplo carregados.')
