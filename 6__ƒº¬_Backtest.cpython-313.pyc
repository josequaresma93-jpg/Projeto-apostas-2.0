import streamlit as st
from core.database import add_league, add_team, get_leagues, get_teams, save_api_setting, get_api_settings
from services.api_placeholders import football_api_status, odds_api_status
from services.seed import seed_leagues

st.title('⚙️ Configurações / APIs')
tab1,tab2=st.tabs(['Ligas e times','APIs'])
with tab1:
    if st.button('Cadastrar ligas base'):
        seed_leagues(); st.success('Ligas base cadastradas.')
    with st.form('cadastros'):
        league=st.text_input('Liga','Série B'); country=st.text_input('País','Brasil'); team=st.text_input('Time','Vila Nova')
        if st.form_submit_button('Cadastrar'):
            add_league(league,country); add_team(team,league); st.success('Cadastro salvo.')
    c1,c2=st.columns(2); c1.dataframe(get_leagues(),use_container_width=True); c2.dataframe(get_teams(),use_container_width=True)
with tab2:
    st.write(football_api_status()); st.write(odds_api_status())
    with st.form('apis'):
        provider=st.selectbox('Provedor',['API-Football','The Odds API','Pinnacle','Outro']); api_key=st.text_input('API Key',type='password'); active=st.checkbox('Ativo')
        if st.form_submit_button('Salvar API'):
            save_api_setting(provider,api_key,1 if active else 0); st.success('Configuração salva.')
    st.dataframe(get_api_settings(),use_container_width=True)
